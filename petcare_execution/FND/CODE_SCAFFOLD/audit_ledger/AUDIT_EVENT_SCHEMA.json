{
  "schema": "petcare-audit-event-schema-v1",
  "generated_at": "2026-03-15T00:00:00Z",
  "phase": "PH-FND-2",
  "event_envelope": {
    "description": "Every audit event stored in audit_ledger conforms to this envelope",
    "fields": {
